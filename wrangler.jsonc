{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "fendam-web",
  "compatibility_date": "2024-11-01",
  // Static-assets-only Worker: serve the Vite build output and fall back to
  // index.html for client-side routes (/investors, /products/:slug).
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  }
}
